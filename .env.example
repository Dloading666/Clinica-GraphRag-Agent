# ===== LLM 配置（支持任意 OpenAI-compatible 服务）=====
LLM_API_KEY=your-llm-api-key
LLM_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
LLM_MODEL=qwen-turbo

# ===== Embedding 配置（可与 LLM 使用不同供应商）=====
EMBEDDING_API_KEY=your-embedding-api-key
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v2
EMBEDDING_DIMENSION=1536

# ===== PostgreSQL =====
# Docker Compose 运行时建议使用 postgres
# 本地直连运行 backend/main.py 时改成 localhost
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=clinical_qa
POSTGRES_USER=postgres
POSTGRES_PASSWORD=clinical_qa_2024

# ===== Neo4j =====
# Docker Compose 运行时建议使用 neo4j://neo4j:7687
# 本地直连运行 backend/main.py 时改成 neo4j://localhost:7687
NEO4J_URI=neo4j://neo4j:7687
NEO4J_USERNAME=neo4j
NEO4J_PASSWORD=clinical_neo4j_2024

# ===== 文本处理 =====
CHUNK_SIZE=800
CHUNK_OVERLAP=200

# ===== 搜索参数 =====
SEARCH_TOP_K=15
SIMILARITY_THRESHOLD=0.82
LOCAL_SEARCH_TOP_CHUNKS=3
LOCAL_SEARCH_TOP_COMMUNITIES=3
LOCAL_SEARCH_TOP_INSIDE_RELS=10
LOCAL_SEARCH_TOP_OUTSIDE_RELS=10
LOCAL_SEARCH_TOP_ENTITIES=10
HYBRID_SEARCH_ENTITY_LIMIT=15

# ===== 性能 =====
MAX_WORKERS=4
BATCH_SIZE=100
EMBEDDING_BATCH_SIZE=64

# ===== 服务 =====
SERVER_HOST=0.0.0.0
SERVER_PORT=8000
SERVER_WORKERS=2
FRONTEND_API_URL=http://localhost:8000
